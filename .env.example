# Ex-Machina Environment Variables
# Copy to .env and fill in values

# Database
POSTGRES_PASSWORD=your-strong-password-here

# Backend
SECRET_KEY=your-secret-key-here
OPENROUTER_API_KEY=sk-or-v1-your-key-here
WEBHOOK_BASE_URL=https://exmachina.kg
BACKEND_CORS_ORIGINS=https://exmachina.kg,http://localhost:3000

# AI defaults
DEFAULT_AI_MODEL=anthropic/claude-3.5-haiku
DEFAULT_MONTHLY_BUDGET=5.0

# Frontend
NEXT_PUBLIC_API_URL=https://exmachina.kg/api
