# Ex-Machina backend env template
# Copy to .env and fill real values. NEVER commit .env (it's gitignored).
# NEVER paste a real key inside any *.md file in this repo (history leaks).

# === App ===
APP_NAME=Ex-Machina
APP_VERSION=1.0.0
DEBUG=true                          # set false in production

# === Database ===
# Local SQLite (no Postgres install needed):
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Railway Postgres (production):
# DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:PORT/DB

# === Auth ===
SECRET_KEY=change-this-in-production-32-bytes-of-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === Registration ===
INVITE_CODE=change-this-in-production

# === Encryption (Fernet for TG/WA tokens in DB) ===
# Generate via:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# === OpenRouter (LLM provider) ===
# Get a key at https://openrouter.ai/settings/keys
# NEVER commit a real key to any *.md file in the repo
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_AI_MODEL=anthropic/claude-3.5-haiku
DEFAULT_MONTHLY_BUDGET=5.0

# === CORS ===
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# === Webhooks ===
WEBHOOK_BASE_URL=                   # e.g. https://exmachina-api.up.railway.app
FRONTEND_BASE_URL=https://exmachina.up.railway.app

# === Demo bot seeding (#9, used by scripts/seed_prod_demo_hotel.py) ===
DEMO_BOT_TOKEN=                     # from @BotFather, format 1234567890:ABC...
DEMO_OWNER_EMAIL=demo@asystem.com
